<Window x:Class="ShabiLite.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="确认操作" Width="520" Height="270"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" Foreground="{DynamicResource PrimaryTextBrush}"
        ShowInTaskbar="False" UseLayoutRounding="True">
    <Border Margin="10" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="#CFC4DF"
            BorderThickness="1" CornerRadius="14" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.26" Color="#382F49" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="66" />
            </Grid.RowDefinitions>

            <Border MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0" Color="#2A2242" />
                        <GradientStop Offset="0.54" Color="#4D378B" />
                        <GradientStop Offset="1" Color="#7C5CE5" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="13,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText" VerticalAlignment="Center" FontSize="12"
                               FontWeight="SemiBold" Foreground="#F2EEFF" Text="确认操作" />
                    <Button Grid.Column="1" Style="{StaticResource WindowCloseButton}" Content="×"
                            Click="CancelButton_Click" ToolTip="关闭"
                            automation:AutomationProperties.Name="关闭确认窗口" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,22,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="52" Height="52" Background="#EEE7FB" CornerRadius="14" VerticalAlignment="Top">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25"
                               FontWeight="Bold" Foreground="{StaticResource PurpleBrush}" Text="!" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="MessageText" FontSize="15" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailText" Margin="0,9,0,0" FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="#F2EDF8" BorderBrush="#DED5E8" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                    <Button MinWidth="92" Content="取消" Click="CancelButton_Click" />
                    <Button MinWidth="112" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}"
                            Content="确认删除" Click="ConfirmButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
